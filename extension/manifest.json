{
  "manifest_version": 3,
  "name": "findEmm",
  "version": "0.1.0",
  "description": "Local-first, evidence-based recruiter enrichment.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:4317/*"],
  "icons": {
    "16": "icons/findemm-16.png",
    "32": "icons/findemm-32.png",
    "48": "icons/findemm-48.png",
    "128": "icons/findemm-128.png"
  },
  "action": { "default_title": "findEmm", "default_popup": "popup.html" },
  "background": { "service_worker": "background.js", "type": "module" }
}
